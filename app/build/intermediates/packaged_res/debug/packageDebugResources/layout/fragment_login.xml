<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="10dp"
            android:scaleType="centerInside" />

        <Space
            android:layout_width="1dp"
            android:layout_height="16dp" />

        <!-- MD SURR Logo -->
        <ImageView
            android:layout_width="110dp"
            android:layout_height="152dp"
            android:src="@drawable/ic_logo_mdsurr"
            android:scaleType="fitCenter"
            android:contentDescription="MD SURR Logo" />

        <Space
            android:layout_width="1dp"
            android:layout_height="24dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enter_mobile_number"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center" />

        <Space
            android:layout_width="1dp"
            android:layout_height="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/otp_subtitle"
            android:textSize="14sp"
            android:textColor="#999999"
            android:gravity="center" />

        <Space
            android:layout_width="1dp"
            android:layout_height="32dp" />

        <!-- Phone input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field">

            <!-- India flag icon -->
            <ImageView
                android:id="@+id/flagIcon"
                android:layout_width="28dp"
                android:layout_height="20dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_flag_india"
                android:scaleType="fitCenter"
                android:contentDescription="Country flag"
                android:clickable="true"
                android:focusable="true" />

            <!-- Dropdown chevron -->
            <ImageView
                android:id="@+id/dropdownIcon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_dropdown"
                android:scaleType="fitCenter"
                android:contentDescription="Select country"
                android:clickable="true"
                android:focusable="true" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@color/divider" />

            <!-- Phone EditText -->
            <EditText
                android:id="@+id/phoneInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Phone"
                android:inputType="phone"
                android:paddingStart="8dp"
                android:paddingEnd="16dp"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:importantForAutofill="no" />

        </LinearLayout>

        <!-- Spacer to push button to bottom -->
        <Space
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Continue button -->
        <Button
            android:id="@+id/continueButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/continue_btn"
            android:background="@drawable/bg_button_teal"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
