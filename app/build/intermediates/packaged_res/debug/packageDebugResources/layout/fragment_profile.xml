<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Top bar: Back arrow + centered title -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="44dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/ic_arrow_back"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/doctor_profile"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Profile Photo with camera overlay -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp">

            <ImageView
                android:id="@+id/profilePhoto"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_person"
                android:background="@drawable/bg_avatar_circle"
                android:scaleType="centerInside"
                android:padding="30dp"
                android:contentDescription="Profile photo" />

            <!-- Camera icon overlay bottom-right -->
            <ImageView
                android:id="@+id/cameraOverlay"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp"
                android:src="@drawable/ic_camera"
                android:background="@drawable/bg_camera_circle"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:contentDescription="Change photo"
                app:tint="@color/white" />
        </FrameLayout>

        <!-- Full Name field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Name icon" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/nameLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/full_name"
                app:boxBackgroundMode="none"
                app:hintTextColor="@color/text_hint"
                app:hintTextAppearance="@style/TaalText.Subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/nameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_underline" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Email field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_mail"
                android:contentDescription="Email icon" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/emailLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/email"
                app:boxBackgroundMode="none"
                app:hintTextColor="@color/text_hint"
                app:hintTextAppearance="@style/TaalText.Subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_underline" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Phone field with flag + dropdown -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/flagIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_flag_india"
                android:contentDescription="Country flag" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_dropdown"
                android:contentDescription="Country code dropdown" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/phoneLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/phone"
                app:boxBackgroundMode="none"
                app:hintTextColor="@color/text_hint"
                app:hintTextAppearance="@style/TaalText.Subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/phoneInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_underline" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Date of Birth field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_calendar"
                android:contentDescription="Calendar icon" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/dobLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/date_of_birth"
                app:boxBackgroundMode="none"
                app:hintTextColor="@color/text_hint"
                app:hintTextAppearance="@style/TaalText.Subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/dobInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date"
                    android:focusable="false"
                    android:clickable="true"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_underline" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Country of Practice field (dropdown) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_location"
                android:contentDescription="Location icon" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/countryLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/country_of_practice"
                app:boxBackgroundMode="none"
                app:hintTextColor="@color/text_hint"
                app:hintTextAppearance="@style/TaalText.Subtitle"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_dropdown">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/countryInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_underline" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Profession field (dropdown) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_building"
                android:contentDescription="Profession icon" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/professionLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:hint="@string/profession"
                app:boxBackgroundMode="none"
                app:hintTextColor="@color/text_hint"
                app:hintTextAppearance="@style/TaalText.Subtitle"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_dropdown">

                <AutoCompleteTextView
                    android:id="@+id/professionDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_underline" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Degree field (dropdown) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_graduation"
                android:contentDescription="Degree icon" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/degreeLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:hint="@string/degree"
                app:boxBackgroundMode="none"
                app:hintTextColor="@color/text_hint"
                app:hintTextAppearance="@style/TaalText.Subtitle"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_dropdown">

                <AutoCompleteTextView
                    android:id="@+id/degreeDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_underline" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Specialty + Subspecialty side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Specialty icon" />

            <!-- Specialty dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/specialtyLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:hint="@string/specialty"
                app:boxBackgroundMode="none"
                app:hintTextColor="@color/text_hint"
                app:hintTextAppearance="@style/TaalText.Subtitle"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_dropdown">

                <AutoCompleteTextView
                    android:id="@+id/specialtyDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_underline" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <!-- Subspecialty dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/subspecialtyLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:hint="@string/subspecialty"
                app:boxBackgroundMode="none"
                app:hintTextColor="@color/text_hint"
                app:hintTextAppearance="@style/TaalText.Subtitle"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_dropdown">

                <AutoCompleteTextView
                    android:id="@+id/subspecialtyDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_underline" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveProfileButton"
            android:layout_width="262dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:text="@string/save"
            style="@style/TaalButton" />

    </LinearLayout>
</ScrollView>
