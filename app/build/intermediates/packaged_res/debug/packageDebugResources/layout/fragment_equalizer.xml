<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Sub Nav Bar: Back arrow (start), Sync + Device (end) -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_marginTop="@dimen/spacing_sm"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/syncButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="@dimen/spacing_xs"
        android:src="@drawable/ic_sync"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Sync"
        android:padding="6dp"
        app:layout_constraintTop_toTopOf="@id/backButton"
        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintEnd_toStartOf="@id/deviceButton" />

    <ImageButton
        android:id="@+id/deviceButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:src="@drawable/ic_bluetooth_device"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Device"
        android:padding="6dp"
        app:layout_constraintTop_toTopOf="@id/backButton"
        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Reset + Save row (below nav bar, right-aligned) -->
    <ImageButton
        android:id="@+id/resetButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="@dimen/spacing_xs"
        android:src="@drawable/ic_reset"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Reset"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/backButton"
        app:layout_constraintEnd_toStartOf="@id/saveButton" />

    <ImageButton
        android:id="@+id/saveButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="@dimen/spacing_xs"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:src="@drawable/ic_save"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Save"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/deviceButton"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Timer Display (centered, same row as reset/save) -->
    <TextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/timer_default"
        style="@style/TaalText.Timer"
        app:layout_constraintTop_toTopOf="@id/resetButton"
        app:layout_constraintBottom_toBottomOf="@id/resetButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/resetButton" />

    <!-- Filter Icon Row + "..." Custom Presets Popup trigger -->
    <LinearLayout
        android:id="@+id/filterRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_xs"
        app:layout_constraintTop_toBottomOf="@id/timerText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/filterHeart"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_heart"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/filter_heart" />

        <ImageButton
            android:id="@+id/filterLungs"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_lungs"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/filter_lungs" />

        <ImageButton
            android:id="@+id/filterBowel"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_bowel"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/filter_bowel" />

        <ImageButton
            android:id="@+id/filterPregnancy"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_pregnancy"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/filter_pregnancy" />

        <ImageButton
            android:id="@+id/filterAccessibility"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_accessibility"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Full Body" />

        <!-- "..." Custom Presets Popup trigger -->
        <ImageButton
            android:id="@+id/presetsButton"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Custom Presets" />

    </LinearLayout>

    <!-- Parametric EQ Curve Area — draws its own log-scale freq labels internally -->
    <View
        android:id="@+id/eqCurveArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_eq_curve"
        app:layout_constraintTop_toBottomOf="@id/filterRow"
        app:layout_constraintBottom_toTopOf="@id/soundTypeBar"
        app:layout_constraintHeight_min="220dp" />

    <!--
        Sound Type Color Bar — aligned to log scale 10Hz–2kHz (same as EQ curve above).
        Log-scale proportions (log base 10):
          Heart  10–250Hz:   log(250/10)/log(2000/10) = log(25)/log(200)  ≈ 60.7%  → weight 607
          Lungs 250–1500Hz:  log(1500/10)/log(200) - 60.7%               ≈ 33.9%  → weight 339
          Noise 1500–2000Hz: 100% - 94.6%                                 ≈  5.4%  → weight 54
        Total weight = 1000 (proportional, no margin inside so it aligns with eqCurveArea).
    -->
    <LinearLayout
        android:id="@+id/soundTypeBar"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:orientation="horizontal"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginTop="2dp"
        app:layout_constraintBottom_toTopOf="@id/playText"
        android:layout_marginBottom="@dimen/spacing_sm">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="607"
            android:background="@color/teal_primary"
            android:text="@string/heart_sound"
            android:textColor="@color/white"
            android:textSize="8sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="339"
            android:background="@color/teal_dark"
            android:text="@string/lungs_sound"
            android:textColor="@color/white"
            android:textSize="8sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="54"
            android:background="@color/eq_noise"
            android:text="@string/noise"
            android:textColor="@color/white"
            android:textSize="7sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Play Recording text -->
    <TextView
        android:id="@+id/playText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/play_recording"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="@dimen/spacing_sm"
        app:layout_constraintBottom_toTopOf="@id/playButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Play Button (large red circle) -->
    <ImageButton
        android:id="@+id/playButton"
        android:layout_width="@dimen/record_button_size"
        android:layout_height="@dimen/record_button_size"
        android:background="@drawable/bg_record_button"
        android:src="@drawable/ic_play"
        android:scaleType="centerInside"
        android:contentDescription="Play"
        android:layout_marginBottom="@dimen/spacing_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
