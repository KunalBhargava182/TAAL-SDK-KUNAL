<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Sub Nav Bar -->
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_marginTop="@dimen/spacing_sm"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/edit_recording"
            style="@style/TaalText.Title"
            android:textSize="18sp"
            app:layout_constraintTop_toTopOf="@id/backButton"
            app:layout_constraintBottom_toBottomOf="@id/backButton"
            app:layout_constraintStart_toEndOf="@id/backButton"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Patient Name + ID row -->
        <TextView
            android:id="@+id/patientNameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_md"
            android:text="Patient Name"
            style="@style/TaalText.Title"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/backButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/patientIdText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="ID: ---"
            style="@style/TaalText.Subtitle"
            app:layout_constraintTop_toBottomOf="@id/patientNameText"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Waveform preview -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/waveformPreview"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_md"
            app:layout_constraintTop_toBottomOf="@id/patientIdText" />

        <!-- BPM + Filter row -->
        <LinearLayout
            android:id="@+id/bpmFilterRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            app:layout_constraintTop_toBottomOf="@id/waveformPreview">

            <TextView
                android:id="@+id/bpmBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- BPM"
                style="@style/TaalText.BPM"
                android:layout_marginEnd="@dimen/spacing_md" />

            <ImageButton
                android:id="@+id/filterHeart"
                android:layout_width="@dimen/filter_icon_size"
                android:layout_height="@dimen/filter_icon_size"
                android:layout_margin="@dimen/spacing_xs"
                android:src="@drawable/ic_heart"
                android:background="@drawable/bg_filter_icon"
                android:scaleType="centerInside"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/filterLungs"
                android:layout_width="@dimen/filter_icon_size"
                android:layout_height="@dimen/filter_icon_size"
                android:layout_margin="@dimen/spacing_xs"
                android:src="@drawable/ic_lungs"
                android:background="@drawable/bg_filter_icon"
                android:scaleType="centerInside"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/filterBowel"
                android:layout_width="@dimen/filter_icon_size"
                android:layout_height="@dimen/filter_icon_size"
                android:layout_margin="@dimen/spacing_xs"
                android:src="@drawable/ic_bowel"
                android:background="@drawable/bg_filter_icon"
                android:scaleType="centerInside"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Patient Details Section -->
        <TextView
            android:id="@+id/detailsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/patient_details"
            style="@style/TaalText.Title"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/bpmFilterRow" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/nameInput"
            style="@style/TaalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:hint="@string/full_name"
            app:layout_constraintTop_toBottomOf="@id/detailsHeader">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/nameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/patientIdInput"
            style="@style/TaalInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:hint="@string/patient_id"
            app:layout_constraintTop_toBottomOf="@id/nameInput">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/patientIdEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Amplify Slider -->
        <TextView
            android:id="@+id/amplifyLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="Amplify (6dB)"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/patientIdInput" />

        <LinearLayout
            android:id="@+id/amplifyRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            app:layout_constraintTop_toBottomOf="@id/amplifyLabel">

            <CheckBox
                android:id="@+id/amplifyCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/teal_primary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/amplifySlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0"
                android:valueTo="10"
                android:stepSize="1"
                android:value="6"
                app:trackColorActive="@color/teal_primary"
                app:trackColorInactive="@color/divider"
                app:thumbColor="@color/teal_primary" />
        </LinearLayout>

        <!-- Noise Reduction Slider -->
        <TextView
            android:id="@+id/noiseReductionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/noise_reduction"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/amplifyRow" />

        <LinearLayout
            android:id="@+id/noiseReductionRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            app:layout_constraintTop_toBottomOf="@id/noiseReductionLabel">

            <CheckBox
                android:id="@+id/noiseReductionCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/teal_primary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/noiseReductionSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0"
                android:valueTo="10"
                android:stepSize="1"
                android:value="5"
                app:trackColorActive="@color/teal_primary"
                app:trackColorInactive="@color/divider"
                app:thumbColor="@color/teal_primary" />
        </LinearLayout>

        <!-- Apply Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/applyButton"
            style="@style/TaalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="@string/apply"
            app:layout_constraintTop_toBottomOf="@id/noiseReductionRow"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
