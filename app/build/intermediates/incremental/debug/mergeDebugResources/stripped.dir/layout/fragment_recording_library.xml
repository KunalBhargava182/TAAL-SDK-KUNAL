<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Top Bar -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_marginTop="@dimen/spacing_sm"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/syncButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:src="@drawable/ic_sync_arrows"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Sync"
        android:scaleType="centerInside"
        app:tint="@color/teal_primary"
        app:layout_constraintTop_toTopOf="@id/backButton"
        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintEnd_toStartOf="@id/bluetoothButton" />

    <ImageButton
        android:id="@+id/bluetoothButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="@dimen/spacing_md"
        android:src="@drawable/ic_bluetooth"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Bluetooth"
        android:scaleType="centerInside"
        app:tint="@color/teal_primary"
        app:layout_constraintTop_toTopOf="@id/backButton"
        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Patient Name -->
    <TextView
        android:id="@+id/patientNameText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/unknown_patient"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/backButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Suman Kalyani" />

    <!-- Patient ID | Visit ID -->
    <TextView
        android:id="@+id/patientInfoText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:textSize="@dimen/text_caption"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/patientNameText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Patient ID: 4204294 | Visit ID: 234896" />

    <!-- Demographics row -->
    <TextView
        android:id="@+id/demographicsText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/patientInfoText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Age: 30   Gender: Male   Phone: +91 77489-49637" />

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_md"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        app:layout_constraintTop_toBottomOf="@id/demographicsText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search"
            app:tint="@color/text_secondary" />

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@android:color/transparent"
            android:hint="@string/search_recording"
            android:textSize="@dimen/text_body"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:inputType="text"
            android:singleLine="true" />

        <ImageButton
            android:id="@+id/filterButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_filter_list"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Filter"
            android:scaleType="centerInside"
            app:tint="@color/teal_primary" />
    </LinearLayout>

    <!-- Filter radio chips row -->
    <HorizontalScrollView
        android:id="@+id/filterChipsScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/searchBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioGroup
            android:id="@+id/filterChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md">

            <RadioButton
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/filter_all"
                android:checked="true"
                android:textSize="@dimen/text_caption"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:button="@android:color/transparent"
                android:background="@drawable/selector_chip_background"
                android:textColor="@color/selector_chip_text_color"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/filterHeartChip"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/filter_heart"
                android:textSize="@dimen/text_caption"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:button="@android:color/transparent"
                android:background="@drawable/selector_chip_background"
                android:textColor="@color/selector_chip_text_color"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/filterLungChip"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/filter_lungs"
                android:textSize="@dimen/text_caption"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:button="@android:color/transparent"
                android:background="@drawable/selector_chip_background"
                android:textColor="@color/selector_chip_text_color"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/filterBowelChip"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/filter_bowel"
                android:textSize="@dimen/text_caption"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:button="@android:color/transparent"
                android:background="@drawable/selector_chip_background"
                android:textColor="@color/selector_chip_text_color"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/filterPregnancyChip"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/filter_pregnancy"
                android:textSize="@dimen/text_caption"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:button="@android:color/transparent"
                android:background="@drawable/selector_chip_background"
                android:textColor="@color/selector_chip_text_color"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/filterFullBodyChip"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/filter_full_body"
                android:textSize="@dimen/text_caption"
                android:button="@android:color/transparent"
                android:background="@drawable/selector_chip_background"
                android:textColor="@color/selector_chip_text_color"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center" />
        </RadioGroup>
    </HorizontalScrollView>

    <!-- Recordings RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recordingsRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_md"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/filterChipsScroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_recording_card" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/emptyStateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_recordings"
        android:textSize="@dimen/text_subtitle"
        android:textColor="@color/text_secondary"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recordingsRecyclerView"
        app:layout_constraintBottom_toBottomOf="@id/recordingsRecyclerView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
