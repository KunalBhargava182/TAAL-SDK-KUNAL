<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <Space
            android:layout_width="1dp"
            android:layout_height="40dp" />

        <!-- MD SURR Logo -->
        <ImageView
            android:layout_width="110dp"
            android:layout_height="152dp"
            android:src="@drawable/ic_logo_mdsurr"
            android:scaleType="fitCenter"
            android:contentDescription="MD SURR Logo" />

        <Space
            android:layout_width="1dp"
            android:layout_height="24dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enter_4_digit_code"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center" />

        <Space
            android:layout_width="1dp"
            android:layout_height="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/otp_sent_message"
            android:textSize="14sp"
            android:textColor="#999999"
            android:gravity="center" />

        <Space
            android:layout_width="1dp"
            android:layout_height="32dp" />

        <!-- OTP container: single rounded container with 4 digit fields -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_input_field"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <EditText
                android:id="@+id/otpDigit1"
                android:layout_width="36dp"
                android:layout_height="match_parent"
                android:background="@null"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/otpDigit2"
                android:layout_width="36dp"
                android:layout_height="match_parent"
                android:background="@null"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/otpDigit3"
                android:layout_width="36dp"
                android:layout_height="match_parent"
                android:background="@null"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/otpDigit4"
                android:layout_width="36dp"
                android:layout_height="match_parent"
                android:background="@null"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:importantForAutofill="no" />

        </LinearLayout>

        <Space
            android:layout_width="1dp"
            android:layout_height="16dp" />

        <!-- Resend OTP row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/didnt_receive_otp"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/resendOtp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/resend_otp"
                android:textSize="14sp"
                android:textColor="@color/teal_primary"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Spacer to push button to bottom -->
        <Space
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Verify button -->
        <Button
            android:id="@+id/verifyButton"
            android:layout_width="262dp"
            android:layout_height="52dp"
            android:text="@string/verify"
            android:background="@drawable/bg_button_teal"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
