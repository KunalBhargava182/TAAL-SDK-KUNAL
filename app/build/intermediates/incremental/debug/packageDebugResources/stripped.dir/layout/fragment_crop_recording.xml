<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Sub Nav Bar -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_marginTop="@dimen/spacing_sm"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/syncButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="@dimen/spacing_xs"
        android:src="@drawable/ic_sync"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Sync"
        android:padding="6dp"
        app:layout_constraintTop_toTopOf="@id/backButton"
        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintEnd_toStartOf="@id/deviceButton" />

    <ImageButton
        android:id="@+id/deviceButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:src="@drawable/ic_bluetooth_device"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Device"
        android:padding="6dp"
        app:layout_constraintTop_toTopOf="@id/backButton"
        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Timer Display -->
    <TextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/timer_default"
        style="@style/TaalText.Timer"
        android:layout_marginTop="@dimen/spacing_sm"
        app:layout_constraintTop_toBottomOf="@id/backButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Filter Icon Row -->
    <LinearLayout
        android:id="@+id/filterRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        app:layout_constraintTop_toBottomOf="@id/timerText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/filterHeart"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_heart"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/filter_heart" />

        <ImageButton
            android:id="@+id/filterLungs"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_lungs"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/filter_lungs" />

        <ImageButton
            android:id="@+id/filterBowel"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_bowel"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/filter_bowel" />

        <ImageButton
            android:id="@+id/filterPregnancy"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_pregnancy"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/filter_pregnancy" />

        <ImageButton
            android:id="@+id/filterAccessibility"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:src="@drawable/ic_accessibility"
            android:background="@drawable/bg_filter_icon"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Full Body" />

    </LinearLayout>

    <!-- Crop Waveform Area (custom view will replace this) -->
    <View
        android:id="@+id/cropWaveformArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_eq_curve"
        app:layout_constraintTop_toBottomOf="@id/filterRow"
        app:layout_constraintBottom_toTopOf="@id/cropTimesRow"
        app:layout_constraintHeight_min="200dp" />

    <!-- Crop Time Labels: start time / end time -->
    <LinearLayout
        android:id="@+id/cropTimesRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingBottom="@dimen/spacing_xs"
        app:layout_constraintBottom_toTopOf="@id/playText">

        <TextView
            android:id="@+id/cropStartTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textSize="12sp"
            android:textColor="@color/teal_primary"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/cropEndTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textSize="12sp"
            android:textColor="@color/teal_primary"
            android:fontFamily="monospace"
            android:gravity="end" />
    </LinearLayout>

    <!-- Play text -->
    <TextView
        android:id="@+id/playText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/play_recording"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="@dimen/spacing_sm"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Bar: Play + Confirm Crop -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="@dimen/spacing_lg"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/playButton"
            android:layout_width="@dimen/record_button_size"
            android:layout_height="@dimen/record_button_size"
            android:layout_marginEnd="@dimen/spacing_xl"
            android:background="@drawable/bg_record_button"
            android:src="@drawable/ic_play"
            android:scaleType="centerInside"
            android:contentDescription="Play" />

        <ImageButton
            android:id="@+id/confirmCropButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_teal"
            android:src="@drawable/ic_check"
            android:scaleType="centerInside"
            android:contentDescription="Confirm Crop"
            android:padding="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
