<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".ui.recording.NewRecordingFragment">

    <TextView
        android:id="@+id/textViewRecordingTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:fontFamily="monospace"
        tools:text="00:00" />

    <!-- Pre-filter selector -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        app:cardBackgroundColor="@color/surface"
        app:cardElevation="2dp"
        app:cardCornerRadius="8dp"
        app:contentPadding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="6">

            <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <ImageView
                    android:id="@+id/imageViewFlagHeart"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    app:srcCompat="@drawable/ic_heart" />
            </FrameLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="@color/divider" />

            <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <ImageView
                    android:id="@+id/imageViewFlagLungs"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    app:srcCompat="@drawable/ic_lungs" />
            </FrameLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="@color/divider" />

            <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <ImageView
                    android:id="@+id/imageViewFlagBowel"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    app:srcCompat="@drawable/ic_bowel" />
            </FrameLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="@color/divider" />

            <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <ImageView
                    android:id="@+id/imageViewFlagPregnancy"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    app:srcCompat="@drawable/ic_pregnancy" />
            </FrameLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="@color/divider" />

            <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <ImageView
                    android:id="@+id/imageViewFlagBody"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    app:srcCompat="@drawable/ic_accessibility" />
            </FrameLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="@color/divider" />

            <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <ImageView
                    android:id="@+id/imageViewFlagCustom"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    app:srcCompat="@drawable/ic_settings" />
            </FrameLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Waveform chart container — LineChart added programmatically -->
    <FrameLayout
        android:id="@+id/fragmentContainerViewWaveForm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />

    <!-- Pre-amplification slider -->
    <RelativeLayout
        android:id="@+id/relativeLayoutPreAmpControllerRoot"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="16dp">

        <!-- dB labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="0"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="1"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="2"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="3"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="4"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="5"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="6"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="7"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="8"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="9"  android:textColor="@color/text_secondary" android:textSize="9sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="10" android:textColor="@color/text_secondary" android:textSize="9sp" />

        </LinearLayout>

        <SeekBar
            android:id="@+id/seekBarPreAmplification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:max="10"
            android:min="0"
            android:progress="5"
            android:progressBackgroundTint="@android:color/transparent"
            android:progressTint="@android:color/transparent"
            android:secondaryProgressTint="@android:color/transparent"
            android:thumbTint="@color/teal_primary"
            android:tickMark="@null" />

    </RelativeLayout>

    <!-- BPM display -->
    <TextView
        android:id="@+id/textViewBPM"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:text="-- BPM"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Recording state label -->
    <TextView
        android:id="@+id/textViewRecordingAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="Start Recording"
        android:textColor="@color/text_primary"
        android:textSize="16sp" />

    <!-- Record button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardViewRecordingBtn"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="36dp"
        app:cardElevation="4dp">

        <ImageView
            android:id="@+id/imageViewRecord"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:padding="12dp"
            app:srcCompat="@drawable/ic_stethoscope_blue" />

    </androidx.cardview.widget.CardView>

</LinearLayout>
