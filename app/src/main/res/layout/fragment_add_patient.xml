<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar: hamburger | red stethoscope | spacer | sync | bluetooth -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/menuButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_menu_hamburger"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                android:scaleType="centerInside" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_stethoscope_red"
                android:scaleType="centerInside"
                android:contentDescription="Stethoscope" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/syncButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_sync_arrows"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Sync"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/bluetoothButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_bluetooth"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bluetooth"
                android:scaleType="centerInside" />
        </LinearLayout>

        <!-- File info row: stethoscope icon + filename + edit icon + timer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_stethoscope_teal"
                android:scaleType="centerInside"
                android:contentDescription="Recording" />

            <TextView
                android:id="@+id/fileNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="recording.surr"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:singleLine="true"
                android:ellipsize="middle" />

            <ImageButton
                android:id="@+id/editFileNameButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Edit file name"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/timerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/timer_default"
                android:textColor="@color/teal_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Search" />

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:hint="@string/search_patient"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:inputType="text"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Search Results dropdown (shown/hidden dynamically) -->
        <LinearLayout
            android:id="@+id/searchResultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@color/white"
            android:elevation="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/addNewPatientOption"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/add_new_patient"
                android:textColor="@color/teal_primary"
                android:textSize="14sp"
                android:background="?attr/selectableItemBackground" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/patientSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintHeight_max="120dp" />
        </LinearLayout>

        <!-- BPM chip + Filter icons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp">

            <TextView
                android:id="@+id/bpmChip"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="99 BPM"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="12sp"
                android:background="@drawable/bg_bpm_chip" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_heart"
                android:scaleType="centerInside"
                android:contentDescription="@string/filter_heart" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_lungs"
                android:scaleType="centerInside"
                android:contentDescription="@string/filter_lungs" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_bowel"
                android:scaleType="centerInside"
                android:contentDescription="@string/filter_bowel" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_pregnancy"
                android:scaleType="centerInside"
                android:contentDescription="@string/filter_pregnancy" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_accessibility"
                android:scaleType="centerInside"
                android:contentDescription="@string/filter_full_body" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:background="@color/divider" />
        </LinearLayout>

        <!-- Patient Details section header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="@string/patient_details"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <!-- Full Name (flat underline input) -->
        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_underline"
            android:hint="@string/full_name"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:inputType="textPersonName" />

        <!-- Patient ID (flat underline input) -->
        <EditText
            android:id="@+id/patientIdInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_underline"
            android:hint="@string/patient_id"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:inputType="text" />

        <!-- Phone (flat underline input) -->
        <EditText
            android:id="@+id/phoneInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_underline"
            android:hint="@string/phone"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:inputType="phone" />

        <!-- Discard + Save buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <Button
                android:id="@+id/discardButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/discard"
                android:background="@drawable/bg_button_gray"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="14sp" />

            <Button
                android:id="@+id/savePatientButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/save"
                android:background="@drawable/bg_button_teal"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Horizontal drag handle / divider -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:background="@color/divider" />

        <!-- Bottom tag dropdowns - 2 column grid -->
        <LinearLayout
            android:id="@+id/tagsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Row 1: Differential Diagnosis | Tentative Diagnosis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/diffDiagnosisDropdown"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_tag_dropdown"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/diffDiagnosisText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/differential_diagnosis"
                        android:textSize="11sp"
                        android:textColor="@color/teal_primary"
                        android:singleLine="true" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_dropdown"
                        app:tint="@color/teal_primary"
                        android:contentDescription="Expand" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tentDiagnosisDropdown"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_tag_dropdown"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tentDiagnosisText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/tentative_diagnosis"
                        android:textSize="11sp"
                        android:textColor="@color/teal_primary"
                        android:singleLine="true" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_dropdown"
                        app:tint="@color/teal_primary"
                        android:contentDescription="Expand" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: Biological Sex | DOB -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/sexDropdown"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_tag_dropdown"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/sexText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/biological_sex"
                        android:textSize="11sp"
                        android:textColor="@color/teal_primary"
                        android:singleLine="true" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_dropdown"
                        app:tint="@color/teal_primary"
                        android:contentDescription="Expand" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dobDropdown"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_tag_dropdown"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/dobText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dob_label"
                        android:textSize="11sp"
                        android:textColor="@color/teal_primary"
                        android:singleLine="true" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_dropdown"
                        app:tint="@color/teal_primary"
                        android:contentDescription="Expand" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3: Age | Weight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/ageDropdown"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_tag_dropdown"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/ageText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/age_label"
                        android:textSize="11sp"
                        android:textColor="@color/teal_primary"
                        android:singleLine="true" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_dropdown"
                        app:tint="@color/teal_primary"
                        android:contentDescription="Expand" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/weightDropdown"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_tag_dropdown"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/weightText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/weight_label"
                        android:textSize="11sp"
                        android:textColor="@color/teal_primary"
                        android:singleLine="true" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_dropdown"
                        app:tint="@color/teal_primary"
                        android:contentDescription="Expand" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 4: Height | History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/heightDropdown"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_tag_dropdown"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/heightText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/height_label"
                        android:textSize="11sp"
                        android:textColor="@color/teal_primary"
                        android:singleLine="true" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_dropdown"
                        app:tint="@color/teal_primary"
                        android:contentDescription="Expand" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/historyDropdown"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_tag_dropdown"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/historyText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/history_label"
                        android:textSize="11sp"
                        android:textColor="@color/teal_primary"
                        android:singleLine="true" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_dropdown"
                        app:tint="@color/teal_primary"
                        android:contentDescription="Expand" />
                </LinearLayout>
            </LinearLayout>

            <!-- Add Notes multiline -->
            <EditText
                android:id="@+id/notesInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/add_notes"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
