<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/menuButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu"
            android:scaleType="centerInside"
            android:src="@drawable/ic_menu_hamburger" />

        <TextView
            android:id="@+id/screenTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="TAAL Recorder"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/syncButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Sync"
            android:scaleType="centerInside"
            android:src="@drawable/ic_sync_arrows"
            android:visibility="gone"
            app:tint="@color/teal_primary" />

        <ImageButton
            android:id="@+id/bluetoothButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Bluetooth"
            android:scaleType="centerInside"
            android:src="@drawable/ic_bluetooth"
            android:visibility="gone"
            app:tint="@color/teal_primary" />

    </LinearLayout>

    <TextView
        android:id="@+id/timerText"
        style="@style/TaalText.Timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:text="@string/timer_default"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <LinearLayout
        android:id="@+id/filterRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        app:layout_constraintTop_toBottomOf="@id/timerText">

        <ImageButton
            android:id="@+id/filterHeart"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:background="@drawable/bg_filter_icon"
            android:contentDescription="@string/filter_heart"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_heart" />

        <ImageButton
            android:id="@+id/filterLungs"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:background="@drawable/bg_filter_icon"
            android:contentDescription="@string/filter_lungs"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_lungs" />

        <ImageButton
            android:id="@+id/filterBowel"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:background="@drawable/bg_filter_icon"
            android:contentDescription="@string/filter_bowel"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_bowel" />

        <ImageButton
            android:id="@+id/filterPregnancy"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:background="@drawable/bg_filter_icon"
            android:contentDescription="@string/filter_pregnancy"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_pregnancy" />

        <ImageButton
            android:id="@+id/filterInfo"
            android:layout_width="@dimen/filter_icon_size"
            android:layout_height="@dimen/filter_icon_size"
            android:layout_margin="@dimen/spacing_xs"
            android:background="@drawable/bg_filter_icon"
            android:contentDescription="@string/filter_full_body"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_accessibility" />

    </LinearLayout>

    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/waveformChart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/spacing_md"
        app:layout_constraintBottom_toTopOf="@id/bpmText"
        app:layout_constraintHeight_min="200dp"
        app:layout_constraintTop_toBottomOf="@id/filterRow" />

    <TextView
        android:id="@+id/bpmText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:text="-- BPM"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_bpm"
        app:layout_constraintBottom_toTopOf="@id/actionText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/actionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:text="@string/start_recording"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@id/recordButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/recordButton"
        android:layout_width="@dimen/record_button_size"
        android:layout_height="@dimen/record_button_size"
        android:layout_marginBottom="@dimen/spacing_md"
        android:background="@drawable/bg_record_button"
        android:contentDescription="Record"
        android:elevation="4dp"
        android:padding="0dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_recording_start1"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_bar_height"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_sm"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/preRecordingButtons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/folderButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_bottom_action_button"
                android:contentDescription="Library"
                android:scaleType="centerInside"
                android:src="@drawable/ic_gallery"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_bottom_action_button"
                android:contentDescription="Settings"
                android:scaleType="centerInside"
                android:src="@drawable/ic_settings"
                android:visibility="gone"
                app:tint="@color/white" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/recordingButtons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/trashButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Discard"
                android:scaleType="centerInside"
                android:src="@drawable/ic_trash" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/playPauseButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_record_button"
                android:contentDescription="Play"
                android:scaleType="centerInside"
                android:src="@drawable/ic_play" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/saveCheckButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Save"
                android:scaleType="centerInside"
                android:src="@drawable/ic_check_save" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>