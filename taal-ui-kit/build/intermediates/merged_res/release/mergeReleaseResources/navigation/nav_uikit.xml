<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_uikit"
    app:startDestination="@id/recordingFragment">

    <fragment
        android:id="@+id/recordingFragment"
        android:name="com.musediagnostics.taal.uikit.recording.RecordingFragment"
        android:label="Recording">

        <action
            android:id="@+id/action_recording_to_player"
            app:destination="@id/playerFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

        <action
            android:id="@+id/action_recording_to_savedRecordings"
            app:destination="@id/savedRecordingsFragment" />

    </fragment>

    <fragment
        android:id="@+id/playerFragment"
        android:name="com.musediagnostics.taal.uikit.player.PlayerFragment"
        android:label="Player">

        <argument
            android:name="filePath"
            app:argType="string"
            android:defaultValue="" />

        <argument
            android:name="isNewRecording"
            app:argType="boolean"
            android:defaultValue="false" />

        <argument
            android:name="filterName"
            app:argType="string"
            android:defaultValue="HEART" />

        <action
            android:id="@+id/action_player_to_savedRecordings"
            app:destination="@id/savedRecordingsFragment" />

    </fragment>

    <fragment
        android:id="@+id/savedRecordingsFragment"
        android:name="com.musediagnostics.taal.uikit.player.SavedRecordingsFragment"
        android:label="Saved Recordings">

        <action
            android:id="@+id/action_savedRecordings_to_player"
            app:destination="@id/playerFragment" />

    </fragment>

</navigation>
